# Example environment file — copy this to .env.local and fill in your real values.
# NEVER commit your real .env or .env.local files to version control.

# Stripe (public key — safe to expose)
VITE_STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY

# Supabase (anon/public key — safe to expose for Vite apps)
# Security is enforced by Supabase Row Level Security (RLS) policies.
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
